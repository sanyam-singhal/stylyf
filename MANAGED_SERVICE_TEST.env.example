# Managed-service test pass env example for Stylyf v0.2.0 follow-up.
# Fill in the real values later when we resume cloud-backed testing.
#
# Stylyf now has two backend paths:
# 1. portable mode: Better Auth + Drizzle + Postgres/Turso
# 2. hosted mode: Supabase auth + Supabase data sdk + Tigris
#
# Keep using Stylyf's generated generic env names inside the emitted app.

# Shared app base URL
APP_BASE_URL=https://your-app.example.com
NODE_ENV=development

# -------------------------------------------------------------------
# Portable branch: Better Auth + Drizzle
# -------------------------------------------------------------------

BETTER_AUTH_URL=https://your-app.example.com
BETTER_AUTH_SECRET=replace-with-a-strong-random-secret

# Better Auth Infrastructure (optional additive managed service)
BETTER_AUTH_API_KEY=replace-with-your-better-auth-infra-api-key

# Portable database backend: Supabase Postgres or Turso libsql
# Use ONE of these, not both.

# Supabase Postgres via Drizzle
# Recommended:
# - direct connection for long-lived servers if IPv6 works
# - Supavisor session mode if you need IPv4
DATABASE_URL=postgres://postgres.<ref>:[PASSWORD]@aws-0-<REGION>.pooler.supabase.com:5432/postgres

# Turso libsql via Drizzle
# DATABASE_URL=libsql://<db-name>-<org>.turso.io
# DATABASE_AUTH_TOKEN=replace-with-your-turso-auth-token

# -------------------------------------------------------------------
# Hosted branch: Supabase auth + Supabase data sdk
# -------------------------------------------------------------------

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# -------------------------------------------------------------------
# Shared storage branch: Tigris / S3-compatible object storage
# -------------------------------------------------------------------

S3_BUCKET=your-bucket-name
AWS_REGION=auto
AWS_ACCESS_KEY_ID=replace-with-your-tigris-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-your-tigris-secret-access-key
AWS_ENDPOINT_URL_S3=https://t3.storage.dev
S3_FORCE_PATH_STYLE=false

# Optional alias names if a project prefers the S3_* form instead:
# S3_REGION=auto
# S3_ACCESS_KEY_ID=replace-with-your-tigris-access-key-id
# S3_SECRET_ACCESS_KEY=replace-with-your-tigris-secret-access-key
# S3_ENDPOINT=https://t3.storage.dev

# Optional public/custom bucket URL
S3_PUBLIC_BASE_URL=
