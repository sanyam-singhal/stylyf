# Generated by Stylyf CLI
# Local development env profile.
# Fill in real values before running backend features.

# Canonical app URL used by auth and server-side absolute links.
# exposure: server
# required
APP_BASE_URL=http://localhost:3000
# Standard Node runtime environment.
# exposure: server
# optional
NODE_ENV=development
# Supabase project URL used by server-side auth and data clients.
# exposure: server
# required
SUPABASE_URL=https://your-project-ref.supabase.co
# Server-side copy of the Supabase publishable key used for SSR auth and request-scoped data access.
# exposure: server
# required
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-only Supabase secret key for privileged admin and bypass-RLS operations.
# exposure: server
# required
SUPABASE_SECRET_KEY=sb_secret_xxx
# Client-exposed Supabase project URL for browser auth flows.
# exposure: public
# required
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Client-exposed Supabase publishable key for browser auth and data access.
# exposure: public
# required
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Object storage region.
# exposure: server
# optional
S3_REGION=us-east-1
# AWS-compatible region alias used by providers such as Tigris.
# exposure: server
# optional
AWS_REGION=auto
# Optional generic bucket alias. AWS_S3_BUCKET is preferred for Tigris.
# exposure: server
# optional
S3_BUCKET=
# AWS-compatible bucket alias used by providers or deployments that prefer AWS_* naming.
# exposure: server
# required
AWS_S3_BUCKET=app-uploads
# Access key used by the S3-compatible storage client.
# exposure: server
# optional
S3_ACCESS_KEY_ID=
# AWS SDK-compatible access key alias used by providers such as Tigris.
# exposure: server
# optional
AWS_ACCESS_KEY_ID=
# Secret key used by the S3-compatible storage client.
# exposure: server
# optional
S3_SECRET_ACCESS_KEY=
# AWS SDK-compatible secret key alias used by providers such as Tigris.
# exposure: server
# optional
AWS_SECRET_ACCESS_KEY=
# Optional generic endpoint for S3-compatible providers such as Tigris or Spaces. AWS_ENDPOINT_URL_S3 is preferred for Tigris.
# exposure: server
# optional
S3_ENDPOINT=
# AWS SDK-compatible S3 endpoint alias used by providers such as Tigris.
# exposure: server
# required
AWS_ENDPOINT_URL_S3=https://t3.storage.dev
# Enable path-style requests for compatible providers that require it.
# exposure: server
# optional
S3_FORCE_PATH_STYLE=false
# Browser origins allowed for direct Tigris/S3 reference uploads.
# exposure: server
# optional
STYLYF_BUILDER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Local root where generated app workspaces are created.
# exposure: server
# optional
STYLYF_BUILDER_ROOT=.stylyf-builder
# GitHub organization for generated private repos.
# exposure: server
# optional
STYLYF_BUILDER_GITHUB_ORG=Depths-AI
# Set false for local smoke when repo creation should be skipped.
# exposure: server
# optional
STYLYF_BUILDER_CREATE_GITHUB_REPOS=false
# Agent adapter: manual, codex-exec, or codex-app-server.
# exposure: server
# optional
STYLYF_BUILDER_AGENT_ADAPTER=manual
# Codex exec flags used by the local harness for a new project turn.
# exposure: server
# optional
CODEX_RUN_FLAGS=exec --json --dangerously-bypass-approvals-and-sandbox
# Codex exec flags used when resuming a persisted project session.
# exposure: server
# optional
CODEX_RESUME_FLAGS=exec resume --json --dangerously-bypass-approvals-and-sandbox
# Public preview host base. Port is appended by the builder.
# exposure: server
# optional
STYLYF_PREVIEW_PUBLIC_BASE=http://localhost
