{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "vinxi/types/client",
      "node"
    ],
    "isolatedModules": true,
    "paths": {
      "~/*": [
        "./src/*"
      ]
    }
  },
  "exclude": [
    "archive",
    ".output",
    ".vinxi",
    "scripts",
    "tests",
    "node_modules"
  ]
}
