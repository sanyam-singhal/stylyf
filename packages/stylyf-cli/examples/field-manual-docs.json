{
  "name": "Field Manual",
  "shell": "docs-shell",
  "theme": {
    "preset": "pearl",
    "mode": "light",
    "radius": "trim",
    "density": "comfortable",
    "spacing": "tight",
    "fonts": {
      "fancy": "Fraunces",
      "sans": "Manrope",
      "mono": "IBM Plex Mono"
    }
  },
  "routes": [
    {
      "path": "/",
      "page": "resource-detail",
      "title": "Getting Started",
      "sections": [
        {
          "layout": "stack",
          "children": [
            {
              "component": "section-header",
              "props": {
                "title": "Install and orient",
                "description": "Start with a stable shell, then use search and generation to assemble the first route set."
              }
            },
            { "component": "accordion" },
            { "component": "table" }
          ]
        }
      ]
    },
    {
      "path": "/guides/composition",
      "page": "resource-detail",
      "title": "Composition Guide",
      "sections": [
        {
          "layout": "stack",
          "children": [
            {
              "component": "section-header",
              "props": {
                "title": "Compose with shells and layouts",
                "description": "Use page shells for rhythm, layouts for space, and copied registry components for the actual UI surface."
              }
            },
            { "component": "tabs" },
            { "component": "timeline" }
          ]
        }
      ]
    }
  ]
}
