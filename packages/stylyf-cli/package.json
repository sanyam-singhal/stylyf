{
  "name": "@depths/stylyf-cli",
  "version": "1.0.0",
  "description": "Agent-operated scaffolding compiler for generating standalone SolidStart apps.",
  "license": "MIT",
  "author": "Depths AI",
  "type": "module",
  "keywords": [
    "solidjs",
    "solidstart",
    "cli",
    "codegen",
    "generator",
    "ui",
    "design-system",
    "frontend",
    "backend",
    "supabase",
    "drizzle",
    "better-auth",
    "tigris",
    "assembly-line"
  ],
  "bin": {
    "stylyf": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Depths-AI/stylyf.git",
    "directory": "packages/stylyf-cli"
  },
  "bugs": {
    "url": "https://github.com/Depths-AI/stylyf/issues"
  },
  "homepage": "https://github.com/Depths-AI/stylyf/tree/main/packages/stylyf-cli",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "rm -rf dist",
    "dev": "node --experimental-strip-types src/bin.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  }
}
